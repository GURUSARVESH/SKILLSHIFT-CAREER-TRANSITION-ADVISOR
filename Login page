<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Career Advisor | Login & Dashboard</title>
    <style>
        :root {
            --primary: #2563eb;
            --secondary: #1e40af;
            --bg: #f1f5f9;
            --white: #ffffff;
            --text: #334155;
            --error: #dc2626;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--bg);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        /* --- UI COMPONENTS --- */
        .card {
            background: var(--white);
            width: 100%;
            max-width: 450px;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .advisor-container { max-width: 700px; display: none; } /* Hidden initially */

        h1 { color: var(--primary); text-align: center; margin-bottom: 8px; }
        p.subtitle { text-align: center; color: #64748b; margin-bottom: 25px; font-size: 0.9em; }

        .form-group { margin-bottom: 20px; }
        label { display: block; font-weight: 600; margin-bottom: 8px; font-size: 14px; }

        input, textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            box-sizing: border-box;
        }

        button {
            width: 100%;
            padding: 15px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover { background: var(--secondary); }

        .error-msg { color: var(--error); font-size: 13px; margin-top: 10px; display: none; text-align: center; }

        /* --- ADVISOR SPECIFIC STYLES --- */
        .result-box { margin-top: 25px; padding: 20px; background: #f8fafc; border-radius: 10px; border-left: 5px solid var(--primary); display: none;}
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 15px; }
        .banner { background: var(--primary); color: white; padding: 15px; border-radius: 8px; display: flex; justify-content: space-around; margin-top: 20px;}
    </style>
</head>
<body>

    <div id="loginPage" class="card">
        <h1>Welcome Back</h1>
        <p class="subtitle">Log in to access your Career AI</p>
        
        <div class="form-group">
            <label>Email Address</label>
            <input type="email" id="email" placeholder="admin@example.com">
        </div>
        <div class="form-group">
            <label>Password</label>
            <input type="password" id="password" placeholder="••••••••">
        </div>
        
        <button onclick="handleLogin()">Login to Dashboard</button>
        <p id="loginError" class="error-msg">Invalid email or password. Try: admin / 1234</p>
    </div>

    <div id="advisorPage" class="card advisor-container">
        <h1>🚀 AI Career Advisor</h1>
        <p class="subtitle">Logged in as: <span id="userDisplay"></span></p>

        <div class="form-group">
            <label>Current Role</label>
            <input type="text" id="role" value="Mechanical Engineer">
        </div>
        <div class="form-group">
            <label>Core Skills</label>
            <input type="text" id="skills" value="AutoCAD, Excel, Python">
        </div>
        <div class="grid">
            <div class="form-group">
                <label>Experience (Years)</label>
                <input type="number" id="exp" value="2">
            </div>
            <div class="form-group">
                <label>Interest</label>
                <input type="text" id="interest" value="Data / Technology">
            </div>
        </div>

        <button onclick="runAnalysis()">Run AI Benchmarking</button>

        <div id="results" class="result-box">
            <h3 style="margin: 0 0 10px 0;">🎯 Recommended Roadmap</h3>
            <div class="grid">
                <div><strong>Paths:</strong> <ul id="pList" style="padding-left:18px; font-size:14px;"></ul></div>
                <div><strong>Learn:</strong> <ul id="sList" style="padding-left:18px; font-size:14px;"></ul></div>
            </div>
            <div class="banner">
                <div style="text-align:center;"><span>Demand</span><br><strong id="dVal"></strong></div>
                <div style="text-align:center;"><span>Salary Range</span><br><strong id="salVal"></strong></div>
            </div>
        </div>
    </div>

    <script>
        // --- LOGIN LOGIC ---
        function handleLogin() {
            const email = document.getElementById('email').value;
            const pass = document.getElementById('password').value;
            
            // Mock Auth: Accept 'admin' or any email with '1234' password
            if (pass === "1234") {
                document.getElementById('loginPage').style.display = 'none';
                document.getElementById('advisorPage').style.display = 'block';
                document.getElementById('userDisplay').innerText = email || "User";
            } else {
                document.getElementById('loginError').style.display = 'block';
            }
        }

        // --- ANALYSIS LOGIC ---
        function runAnalysis() {
            const role = document.getElementById('role').value;
            const skills = document.getElementById('skills').value.toLowerCase();
            
            let data = {};
            if(role.toLowerCase().includes("mechanical") && skills.includes("python")) {
                data = {
                    paths: ["Data Analyst", "Business Analyst", "Supply Chain Analyst"],
                    skills: ["SQL", "Power BI", "Statistics"],
                    demand: "High",
                    salary: "₹6–12 LPA"
                };
            } else {
                data = {
                    paths: ["IT Consultant"],
                    skills: ["Cloud Basics", "Agile"],
                    demand: "Medium",
                    salary: "₹4–7 LPA"
                };
            }

            document.getElementById('pList').innerHTML = data.paths.map(p => `<li>${p}</li>`).join('');
            document.getElementById('sList').innerHTML = data.skills.map(s => `<li>${s}</li>`).join('');
            document.getElementById('dVal').innerText = data.demand;
            document.getElementById('salVal').innerText = data.salary;
            document.getElementById('results').style.display = 'block';
        }
    </script>
</body>
</html>
