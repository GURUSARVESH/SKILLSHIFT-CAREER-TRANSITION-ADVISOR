<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Career Advisor</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="container">
        <h1>🤖 AI Career Advisor</h1>
        <p class="subtitle">Transitioning Engineering Talent to Tech</p>

        <div class="input-section">
            <div class="form-group">
                <label>Current Role</label>
                <input type="text" id="role" placeholder="e.g. Mechanical Engineer">
            </div>
            
            <div class="form-group">
                <label>Skills</label>
                <input type="text" id="skills" placeholder="e.g. AutoCAD, Python, Excel">
            </div>

            <div class="grid-inputs">
                <div class="form-group">
                    <label>Experience (Years)</label>
                    <input type="number" id="exp" value="2">
                </div>
                <div class="form-group">
                    <label>Interests</label>
                    <input type="text" id="interest" placeholder="e.g. Data Science">
                </div>
            </div>

            <button id="submitBtn">Analyze My Career</button>
        </div>

        <div id="resultSection" class="hidden">
            <div class="result-card">
                <h2>🎯 Analysis Results</h2>
                
                <div class="result-grid">
                    <div class="path-box">
                        <h3>Recommended Paths</h3>
                        <ul id="pathList"></ul>
                    </div>
                    
                    <div class="skills-box">
                        <h3>Skills to Learn</h3>
                        <ul id="skillList"></ul>
                    </div>
                </div>

                <div class="market-stats">
                    <div class="stat">
                        <span>Market Demand:</span>
                        <strong id="demandVal"></strong>
                    </div>
                    <div class="stat">
                        <span>Est. Salary:</span>
                        <strong id="salaryVal"></strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
